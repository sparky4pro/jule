	fn _Comparable(&self, mut e: &eval, mut fc: &ast::CallExpr): &Value {
		if len(fc.Args) > 0 {
			e.pushErr(fc.Token, "passed more argument than expected to Comparable")
			e.pushSuggestion("call like; Comparable()")
