		}
	}

	fn subIdent(mut &self, name: string): &Value {
		match name {
		| "Path":
			mut method := &FuncIns{
				caller: fn|mut e, mut fc, _| self._Path(e, fc),
			}
			return buildAsComptimeMethodData(method)
		| "Name":
			mut method := &FuncIns{
				caller: fn|mut e, mut fc, _| self._Name(e, fc),
			}
			return buildAsComptimeMethodData(method)
		| "Dir":
			mut method := &FuncIns{
				caller: fn|mut e, mut fc, _| self._Dir(e, fc),
