		mut constant := constant::NewBool(self.base.NilCompatible())
		return &Value{
			untyped:  true,
			Type:     primBool,
			Constant: constant,
			Model:    constant,
		}
	}

	fn _GC(mut &self, mut e: &eval, mut fc: &ast::CallExpr): &Value {
		if len(fc.Args) > 0 {
			e.pushErr(fc.Token, "passed more argument than expected to GC")
			e.pushSuggestion("call like; GC()")
