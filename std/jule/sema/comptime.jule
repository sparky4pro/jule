			return buildAsComptimeMethodData(method)
		| "Type":
			mut method := &FuncIns{
				caller: fn|mut e, mut fc, _| self._Type(e, fc),
			}
			return buildAsComptimeMethodData(method)
		|:
			return nil
		}
	}
}

