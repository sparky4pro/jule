#test
fn testMissingRetChecker(t: &testing::T) {
	for i, test in missingRetCheckerTests {
		err := checkSema(test.code)
		if err != test.err {
			t.Errorf("#{} expected {}, found {}", i, test.err, err)
			println(test.code)
		}
	}
}