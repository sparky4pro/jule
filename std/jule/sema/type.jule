// This file reserved for types, type kinds and type build algorithms.
// This file haven't type compatibility checking algorithm or something else.

use "std/conv"
use "std/jule/ast"
use "std/jule/build"
use "std/jule/log"
use "std/jule/token"
use "std/jule/types"
use "std/strings"

// Single mask value for a constraint.
struct ConstraintMask {
	Deep: bool // Whether the operator ~ used.
	Type: &Type
}

impl ConstraintMask {
	fn String(*self): string {
		if self.Deep {
			return "~" + self.Type.String()
		}
		return self.Type.String()
	}
}

// Generic type for instance types.
struct InsGeneric {
	Type:       &Type
	Constraint: []ConstraintMask
}

// Type alias.
struct TypeAlias {
	Scope:    &ast::ScopeTree
	Strict:   bool
	Public:   bool
	Extern:   bool
	Used:     bool
	Generic:  bool
	Token:    &token::Token
	Name:     string
	TypeSym:  &TypeSym
	Generics: []&ast::Generic // See the developer reference (3).
}

// Kind of type declaration.
trait Kind {
	fn String(*self): string
	fn Equal(&self, other: &Type): bool
}

// Evaluated type declaration.
struct Type {
	Provider: string // Identifier of the type alias, if type provided by a type alias.
	Generic:  bool
	Variadic: bool
	Kind:     Kind
}

impl Kind for Type {
	// Returns kind as string.
	fn String(*self): string {
		// Use the provider identifier as type.
		// If type source is a generic, return the actual type.
		// Because name of the generic type might be confusing,
		// expose the current type of the generic.
		if self.Provider != "" && !self.Generic {
			return self.Provider
		}
		if self.IsNil() {
			return "nil"
		}

		mut kind := strings::Builder{}
		kind.Grow(1 << 4)

		if self.Variadic {
			kind.WriteString("...")!
		}
		kind.WriteString(self.Kind.String())!
		return kind.String()
	}

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		if self.IsNil() {
			return other.IsNil()
		}
		return self.Kind.Equal(other)
	}
}

impl Type {
	// Reports whether type is external kind.
	fn Extern(*self): bool {
		s, ok := self.Kind.(&StructIns)
		if ok {
			if s.Decl.Extern {
				return true
			}
			if s.Source != nil {
				return s.Source.Extern()
			}
		}
		return false
	}

	// Reports whether kind is "nil".
	fn IsNil(*self): bool { return self.Kind == nil }

	// Reports whether actual kind is "void".
	fn Void(*self): bool {
		prim := unsafe { (*(&self)).Prim() }
		return prim != nil && prim.Kind == "void"
	}

	// Returns actual kind of the type, so returns the root type.
	// If kind is a struct, which is implemented by the type statement,
	// see developer reference (9) for details, returns the actual kind of
	// the source type of the struct.
	fn ActualKind(mut *self): Kind {
		mut s, ok := self.Kind.(&StructIns)
		if ok && s.Source != nil {
			return s.Source.ActualKind()
		}
		return self.Kind
	}

	// Reports whether actual kinds are equal.
	fn ActualEqual(&self, other: &Type): bool {
		if self.IsNil() {
			return other.IsNil()
		}
		if self.Extern() || other.Extern() {
			return self.Equal(other)
		}
		l := unsafe { (*(&self)).ActualKind() }
		r := unsafe { (*(&other)).ActualKind() }
		lt := Type{Kind: l}
		rt := Type{Kind: r}
		return (unsafe { (&Type)(&lt) }).Equal(unsafe { (&Type)(&rt) })
	}

	// Same as the ActualEqual, but ignores the external types.
	fn deepActualEqual(&self, other: &Type): bool {
		if self.IsNil() {
			return other.IsNil()
		}
		l := unsafe { (*(&self)).ActualKind() }
		r := unsafe { (*(&other)).ActualKind() }
		lt := Type{Kind: l}
		rt := Type{Kind: r}
		return (unsafe { (&Type)(&lt) }).Equal(unsafe { (&Type)(&rt) })
	}

	// Reports whether actual kind is comparable.
	fn Comparable(*self): bool {
		unsafe {
			mut _self := *(&self)
			if _self.SoftStruct() != nil {
				return _self.SoftStruct().Comparable
			}
			if _self.Array() != nil {
				return _self.Array().Value.Comparable()
			}
			return _self.Map() == nil && _self.Slice() == nil && _self.Func() == nil
		}
	}

	// Reports whether actual kind is mutable.
	fn Mutable(*self): bool {
		unsafe {
			mut _self := *(&self)
			if _self.SoftStruct() != nil {
				return _self.SoftStruct().Mutable
			}
			if _self.Chan() != nil {
				return _self.Chan().Value.Mutable()
			}
			if _self.Trait() != nil || _self.TypeEnum() != nil {
				return true
			}
			if _self.Prim() != nil {
				p := _self.Prim()
				return p.IsAny()
			}
			if _self.Array() != nil {
				return _self.Array().Value.Mutable()
			}
			if _self.Map() != nil {
				m := _self.Map()
				return m.Key.Mutable() || m.Value.Mutable()
			}
			return _self.Slice() != nil ||
				_self.Ptr() != nil ||
				_self.Sptr() != nil
		}
	}

	// Reports whether actual kind supports ordered constraint.
	fn Ordered(*self): bool {
		unsafe {
			mut _self := *(&self)
			prim := _self.Prim()
			if prim != nil {
				return types::IsNum(prim.Kind) || prim.IsString()
			}
			mut enm := _self.Enum()
			if enm != nil {
				return types::IsNum(enm.TypeSym.Type.Prim().String())
			}
			return false
		}
	}

	// Reports whether actual kind is nil compatible.
	fn NilCompatible(*self): bool {
		unsafe {
			mut _self := *(&self)

			prim := _self.Prim()
			if prim != nil && prim.IsAny() {
				return true
			}

			return _self.IsNil() ||
				_self.Func() != nil ||
				_self.Sptr() != nil ||
				_self.Ptr() != nil ||
				_self.Trait() != nil ||
				_self.Slice() != nil ||
				_self.Map() != nil ||
				_self.TypeEnum() != nil ||
				_self.Chan() != nil
		}
	}

	// Reports whether actual kind performs garbage collection.
	fn GC(*self): bool {
		unsafe {
			mut _self := *(&self)
			prim := _self.Prim()
			if prim != nil {
				return prim.IsAny() || prim.IsString()
			}
			return _self.Sptr() != nil || _self.Slice() != nil || _self.Trait() != nil ||
				_self.TypeEnum() != nil || _self.Chan() != nil
		}
	}

	// Reports whether actual kind is variadicable.
	fn Variadicable(*self): bool {
		unsafe {
			mut _self := *(&self)
			return _self.Slice() != nil
		}
	}

	// Returns primitive type if actual kind is primitive type, nil if not.
	fn Prim(mut *self): &Prim {
		mut p, _ := self.ActualKind().(&Prim)
		return p
	}

	// Returns channel type if actual kind is channel, nil if not.
	fn Chan(mut *self): &Chan {
		mut c, _ := self.ActualKind().(&Chan)
		return c
	}

	// Returns reference type if actual kind is smart pointer, nil if not.
	fn Sptr(mut *self): &Sptr {
		mut p, _ := self.ActualKind().(&Sptr)
		return p
	}

	// Returns pointer type if actual kind is pointer, nil if not.
	fn Ptr(mut *self): &Ptr {
		mut p, _ := self.ActualKind().(&Ptr)
		return p
	}

	// Returns enum type if actual kind is enum, nil if not.
	fn Enum(mut *self): &Enum {
		mut e, _ := self.ActualKind().(&Enum)
		return e
	}

	// Returns type enum if actual kind is type enum, nil if not.
	fn TypeEnum(mut *self): &TypeEnum {
		mut e, _ := self.ActualKind().(&TypeEnum)
		return e
	}

	// Returns array type if actual kind is array, nil if not.
	fn Array(mut *self): &Array {
		mut a, _ := self.ActualKind().(&Array)
		return a
	}

	// Returns slice type if actual kind is slice, nil if not.
	fn Slice(mut *self): &Slice {
		mut s, _ := self.ActualKind().(&Slice)
		return s
	}

	// Returns function type if actual kind is function, nil if not.
	fn Func(mut *self): &FuncIns {
		mut f, _ := self.ActualKind().(&FuncIns)
		return f
	}

	// Returns struct type if actual kind is structure, nil if not.
	fn Struct(mut *self): &StructIns {
		mut s, _ := self.ActualKind().(&StructIns)
		return s
	}

	// Returns struct type if actual kind is structure.
	// If type kind is the strict type alias source, returns the underlying
	// structure type of the strict type alias.
	fn SoftStruct(mut *self): &StructIns {
		mut s, _ := self.Kind.(&StructIns)
		return s
	}

	// Returns trait type if actual kind is trait, nil if not.
	fn Trait(mut *self): &Trait {
		mut t, _ := self.ActualKind().(&Trait)
		return t
	}

	// Returns map type if actual kind is map, nil if not.
	fn Map(mut *self): &Map {
		mut m, _ := self.ActualKind().(&Map)
		return m
	}

	// Returns tuple type if actual kind is tuple, nil if not.
	fn Tuple(mut *self): &Tuple {
		mut t, _ := self.ActualKind().(&Tuple)
		return t
	}

	// Reports whether kind is comptime type.
	// It will not check for the [comptimeRange].
	// Checks regular constant comptime expression types only.
	fn comptime(mut *self): bool {
		return self.comptimeTypeInfos() != nil ||
			self.comptimeTypeInfo() != nil ||
			self.comptimeStructFields() != nil ||
			self.comptimeStructField() != nil ||
			self.comptimeEnumFields() != nil ||
			self.comptimeEnumField() != nil ||
			self.comptimeStatics() != nil ||
			self.comptimeStatic() != nil ||
			self.comptimeParams() != nil ||
			self.comptimeParam() != nil ||
			self.comptimeValue() != nil ||
			self.comptimeFiles() != nil ||
			self.comptimeFile() != nil ||
			self.comptimeDecl() != nil ||
			self.comptimeDecls() != nil
	}

	fn comptimeStructFields(mut *self): &comptimeStructFields {
		mut ct, _ := self.Kind.(&comptimeStructFields)
		return ct
	}

	fn comptimeStructField(mut *self): &comptimeStructField {
		mut ct, _ := self.Kind.(&comptimeStructField)
		return ct
	}

	fn comptimeEnumFields(mut *self): &comptimeEnumFields {
		mut ct, _ := self.Kind.(&comptimeEnumFields)
		return ct
	}

	fn comptimeEnumField(mut *self): &comptimeEnumField {
		mut ct, _ := self.Kind.(&comptimeEnumField)
		return ct
	}

	fn comptimeParams(mut *self): &comptimeParams {
		mut ct, _ := self.Kind.(&comptimeParams)
		return ct
	}

	fn comptimeParam(mut *self): &comptimeParam {
		mut ct, _ := self.Kind.(&comptimeParam)
		return ct
	}

	fn comptimeRange(mut *self): &comptimeRange {
		mut ct, _ := self.Kind.(&comptimeRange)
		return ct
	}

	fn comptimeTypeInfos(mut *self): &comptimeTypeInfos {
		mut ct, _ := self.Kind.(&comptimeTypeInfos)
		return ct
	}

	fn comptimeTypeInfo(mut *self): &comptimeTypeInfo {
		mut ct, _ := self.Kind.(&comptimeTypeInfo)
		return ct
	}

	fn comptimeStatics(mut *self): &comptimeStatics {
		mut ct, _ := self.Kind.(&comptimeStatics)
		return ct
	}

	fn comptimeStatic(mut *self): &comptimeStatic {
		mut ct, _ := self.Kind.(&comptimeStatic)
		return ct
	}

	fn comptimeValue(mut *self): &comptimeValue {
		mut ct, _ := self.Kind.(&comptimeValue)
		return ct
	}

	fn comptimeDecl(mut *self): &comptimeDecl {
		mut ct, _ := self.Kind.(&comptimeDecl)
		return ct
	}

	fn comptimeDecls(mut *self): &comptimeDecls {
		mut ct, _ := self.Kind.(&comptimeDecls)
		return ct
	}

	fn comptimeFile(mut *self): &comptimeFile {
		mut ct, _ := self.Kind.(&comptimeFile)
		return ct
	}

	fn comptimeFiles(mut *self): &comptimeFiles {
		mut ct, _ := self.Kind.(&comptimeFiles)
		return ct
	}
}

// Type.
struct TypeSym {
	Decl: &ast::Expr // Never changed by semantic analyzer.
	Type: &Type
}

impl TypeSym {
	// Reports whether type is checked already.
	fn checked(*self): bool { return self.Type != nil }

	// Removes kind and ready to check.
	// checked() reports false after this function.
	fn removeKind(mut *self) { self.Type = nil }
}

// Primitive type.
struct Prim {
	Kind: string
}

impl Kind for Prim {
	// Returns kind.
	fn String(*self): string {
		return self.Kind
	}

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		p, ok := other.Kind.(&Prim)
		return ok && self == p
	}
}

impl Prim {
	// Reports whether type is built-in constraint.
	fn IsConstraint(*self): bool {
		return !self.IsString() &&
			!self.IsAny() &&
			!self.IsBool() &&
			!types::IsNum(self.Kind)
	}

	// Reports whether type is primitive i8.
	fn IsI8(*self): bool { return self.Kind == types::I8 }

	// Reports whether type is primitive i16.
	fn IsI16(*self): bool { return self.Kind == types::I16 }

	// Reports whether type is primitive i32.
	fn IsI32(*self): bool { return self.Kind == types::I32 }

	// Reports whether type is primitive i64.
	fn IsI64(*self): bool { return self.Kind == types::I64 }

	// Reports whether type is primitive u8.
	fn IsU8(*self): bool { return self.Kind == types::U8 }

	// Reports whether type is primitive u16.
	fn IsU16(*self): bool { return self.Kind == types::U16 }

	// Reports whether type is primitive u32.
	fn IsU32(*self): bool { return self.Kind == types::U32 }

	// Reports whether type is primitive u64.
	fn IsU64(*self): bool { return self.Kind == types::U64 }

	// Reports whether type is primitive f32.
	fn IsF32(*self): bool { return self.Kind == types::F32 }

	// Reports whether type is primitive f64.
	fn IsF64(*self): bool { return self.Kind == types::F64 }

	// Reports whether type is primitive cmplx64.
	fn IsCmplx64(*self): bool { return self.Kind == types::Cmplx64 }

	// Reports whether type is primitive cmplx128.
	fn IsCmplx128(*self): bool { return self.Kind == types::Cmplx128 }

	// Reports whether type is primitive int.
	fn IsInt(*self): bool { return self.Kind == types::Int }

	// Reports whether type is primitive uint.
	fn IsUint(*self): bool { return self.Kind == types::Uint }

	// Reports whether type is primitive uintptr.
	fn IsUintptr(*self): bool { return self.Kind == types::Uintptr }

	// Reports whether type is primitive bool.
	fn IsBool(*self): bool { return self.Kind == types::Bool }

	// Reports whether type is primitive string.
	fn IsString(*self): bool { return self.Kind == types::String }

	// Reports whether type is primitive any.
	fn IsAny(*self): bool { return self.Kind == types::Any }
}

// Channel type.
struct Chan {
	Recv:  bool
	Send:  bool
	Value: &Type
}

impl Kind for Chan {
	// Returns smart pointer kind as string.
	fn String(*self): string {
		if self.Recv && self.Send {
			c, ok := self.Value.Kind.(&Chan)
			if ok && c.Recv && !c.Send {
				return "chan (" + self.Value.String() + ")"
			}
			return "chan " + self.Value.String()
		} else if self.Recv {
			return "<-chan " + self.Value.String()
		} else {
			return "chan<- " + self.Value.String()
		}
	}

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		c, ok := other.Kind.(&Chan)
		return ok && self.Recv == c.Recv && self.Send == c.Send && self.Value.Equal(c.Value)
	}
}

// Smart pointer.
struct Sptr {
	Value: &Type
}

impl Kind for Sptr {
	// Returns smart pointer kind as string.
	fn String(*self): string { return "&" + self.Value.String() }

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		p, ok := other.Kind.(&Sptr)
		return ok && self.Value.Equal(p.Value)
	}
}

// Slice type.
struct Slice {
	Value: &Type
}

impl Kind for Slice {
	// Returns slice kind as string.
	fn String(*self): string { return "[]" + self.Value.String() }

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		s, ok := other.Kind.(&Slice)
		return ok && self.Value.Equal(s.Value)
	}
}

// Tuple type.
struct Tuple {
	Types: []&Type
}

impl Kind for Tuple {
	// Returns tuple kind as string.
	fn String(*self): string {
		mut s := strings::Builder{}
		s.Grow(1 << 4)
		s.WriteByte('(')!
		s.WriteString(self.Types[0].String())!
		for _, t in self.Types[1:] {
			s.WriteByte(',')!
			s.WriteString(t.String())!
		}
		s.WriteByte(')')!
		return s.String()
	}

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		tup, ok := other.Kind.(&Tuple)
		if !ok || len(self.Types) != len(tup.Types) {
			return false
		}
		mut i := 0
		for i < len(self.Types); i++ {
			if !self.Types[i].Equal(tup.Types[i]) {
				return false
			}
		}
		return true
	}
}

// Map type.
struct Map {
	Key:   &Type
	Value: &Type
}

impl Kind for Map {
	// Returns map kind as string.
	fn String(*self): string {
		mut s := strings::Builder{}
		s.Grow(1 << 4)
		s.WriteString("map[")!
		s.WriteString(self.Key.String())!
		s.WriteByte(']')!
		s.WriteString(self.Value.String())!
		return s.String()
	}

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		m, ok := other.Kind.(&Map)
		return ok && self.Key.Equal(m.Key) && self.Value.Equal(m.Value)
	}
}

// Array type.
struct Array {
	Auto:  bool // Auto-sized array.
	N:     int
	Value: &Type
}

impl Kind for Array {
	// Returns array kind as string.
	fn String(*self): string {
		mut s := strings::Builder{}
		s.WriteByte('[')!
		s.WriteString(conv::Itoa(self.N))!
		s.WriteByte(']')!
		s.WriteString(self.Value.String())!
		return s.String()
	}

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		a, ok := other.Kind.(&Array)
		return ok && self.N == a.N && self.Value.Equal(a.Value)
	}
}

// Pointer type.
struct Ptr {
	Value: &Type
}

impl Kind for Ptr {
	// Returns pointer kind as string.
	fn String(*self): string {
		if self.IsUnsafe() {
			return "*unsafe"
		}
		return "*" + self.Value.String()
	}

	// Reports whether types are same.
	fn Equal(&self, other: &Type): bool {
		p, ok := other.Kind.(&Ptr)
		if !ok {
			return false
		}
		match {
		| self.IsUnsafe():
			return p.IsUnsafe()
		| p.IsUnsafe():
			return self.IsUnsafe()
		|:
			return self.Value.Equal(p.Value)
		}
	}
}

impl Ptr {
	// Reports whether pointer is unsafe pointer (*unsafe).
	fn IsUnsafe(*self): bool { return self.Value == nil }
}

struct referencer {
	owner: any         // StructIns, TypeAlias.
	name:  string      // Name of the owner.
	tains: bool        // Whether owner is the TA-sensitive StructIns.
	oself: bool        // Only self references. It used to caught type alias cycles.
	prev:  &referencer // Previous referencer.
	next:  &referencer // Next referencer.
}

enum recheckableType: type {
	&Type,
	&StructIns,
}

// Cycle state flags.
const (
	cycleErrDisable = 1 << iota // Disable error logging for cycle analysis.
	cycleErrFail                // Means the last cycle analysis reports cycles exist.
)

// Type analysis flags.
// See developer reference (10).
const (
	taNotComparable = 1 << iota // current type is not comparable
	taMutable                   // current type is mutable
)

// Checks type and builds result as kind.
// Removes kind if error occurs,
// so type is not reports true for checked state.
struct typeChecker {
	// Uses sema for:
	//	- Push errors.
	s: &sema

	// Uses Lookup for:
	//	- Lookup symbol tables for root specific.
	rootLookup: Lookup

	// Uses Lookup for:
	//	- Lookup symbol tables for current.
	//	- It might be change when evaluation of namespace selection or etc.
	lookup: Lookup

	// If this is not nil, appends referred ident types.
	// Also used as checker owner.
	referencer: &referencer

	// If this not nil, type dependencies will push into stack.
	refers: &ReferenceStack

	errorToken: &token::Token

	// This identifiers ignored and
	// appends as primitive type.
	//
	// Each dimension 2 array accepted as identifier group.
	ignoreGenerics: []&ast::Generic

	// Relevant type kinds that contains an ignored generic type.
	ignoredGenerics: *[]&Type

	// See developer reference (15).
	recheckNeed: *[]recheckableType

	// This generics used as type alias for real kind.
	useGenerics: []&TypeAlias

	cycleErr: int

	// Disallow/suppress Jule's built-in defines.
	disBuiltin: bool

	// Name selection is enabled.
	// No external definitions, no generic type representation.
	// Only typename selection.
	//
	// If selection is a struct, returns invalid instance that only has decl field.
	selection: bool

	// Disabled type analysis flags.
	disableTA: int
}

impl typeChecker {
	fn pushErr(mut *self, token: &token::Token, fmt: string, args: ...any) {
		self.s.pushErr(token, fmt, args...)
	}

	fn allowBuiltin(mut *self) {
		self.disBuiltin = false
	}

	fn disallowBuiltin(mut *self) {
		self.disBuiltin = true
	}

	fn isIgnoredGeneric(mut *self, name: string): bool {
		for _, g in self.ignoreGenerics {
			if g.Name == name {
				return true
			}
		}
		return false
	}

	// Push type analysis flag to owner structure instance if exist.
	// See developer reference (10).
	fn pushTA(mut *self, tags: int) {
		if self.referencer != nil && self.referencer.tains {
			mut s := (&StructIns)(nil)
			match type self.referencer.owner {
			| &StructIns:
				s = self.referencer.owner.(&StructIns)
			| &TypeAlias:
				s = self.referencer.owner.(&TypeAlias).TypeSym.Type.SoftStruct()
			|:
				panic("unreachable")
			}
			if self.disableTA&taNotComparable == 0 {
				s.Comparable = s.Comparable && tags&taNotComparable == 0
			}
			if self.disableTA&taMutable == 0 {
				s.Mutable = s.Mutable || tags&taMutable != 0
			}
		}
	}

	fn pushReference[T](mut *self, mut t: &T) {
		if self.refers == nil {
			return
		}
		if self.refers.Exist(t) {
			return
		}
		self.refers.Push(t)
	}

	fn pushReferenceByKind(mut *self, mut k: &Type) {
		match {
		| k.SoftStruct() != nil:
			mut t := k.SoftStruct()
			self.pushReference(t)
		| k.Trait() != nil:
			mut t := k.Trait()
			self.pushReference(t)
		}

		// Push references to runtime implementations.
		// We can use nil pointer for token, because it never be used.
		// Since the k is actually based on type alias, the actual type is already instantiated.
		// Therefore, the pushRuntimeImpl function just will add an reference to exist instance.
		match {
		| k.Map() != nil:
			mut m := k.Map()
			self.pushRuntimeImpl("hmap", nil, m.Key, m.Value)
		| k.Chan() != nil:
			mut ch := k.Chan()
			self.pushRuntimeImpl("pchan", nil, ch.Value)
		}
	}

	// Push runtime built-in type implementation instance.
	// Such as map or channel implementations.
	fn pushRuntimeImpl(mut *self, name: string, mut token: &token::Token, mut types: ...&Type) {
		// Runtime metadata collection is disabled.
		// Return immediately, there is not nothing we can do.
		if self.s.meta.runtime == nil {
			return
		}
		mut s := runtimeFindStruct(self.s.meta.runtime, name)
		mut ins := s.instance()
		ins.Generics = make([]&InsGeneric, len(types))
		for (i, mut t) in types {
			ins.Generics[i] = &InsGeneric{Type: t}
		}

		// If the type depends to an ignored generic, add it to recheckNeed.
		// We have to check it with recheck strategy, like user defined structs.
		if len(self.ignoreGenerics) > 0 {
			for (_, mut typ) in types {
				prim := typ.Prim()
				if prim != nil && self.isIgnoredGeneric(prim.Kind) {
					unsafe { *self.recheckNeed = append(*self.recheckNeed, ins) }
					return
				}
			}
		}

		ins = self.fromStructIns(ins, token)
		self.pushReference(ins)
	}

	fn pushCycleError(*self, def1: string, def2: string, mut &message: *strings::Builder) {
		const Padding = 7
		refersTo := log::Logf("@ refers to @", def1, def2)
		message.WriteString(strings::Repeat(" ", Padding))!
		message.WriteString(refersTo)!
		message.WriteByte('\n')!
	}

	fn checkCrossCycle(mut *self, mut decl: any, mut &message: *strings::Builder): (ok: bool, oselfExist: bool) {
		// No cross risk, because referencer have not any previous node.
		// Referencer is the root referencer.
		// So, it is means there are only inline cycle possibility,
		// but it is already checked.
		if self.referencer.prev == nil {
			return true, self.referencer.oself
		}
		mut r := self.referencer
		for r != nil && r.prev != nil; r = r.prev {
		}
		mut root := r
		printErr := fn(mut &message: *strings::Builder) {
			r = root
			for r != nil && r.next != nil; r = r.next {
				unsafe { self.pushCycleError(r.name, r.next.name, message) }
			}
			unsafe { self.pushCycleError(r.name, root.name, message) }
		}
		mut oself := (&referencer)(nil)
		for r != nil; r = r.next {
			if oself != nil {
				if oself.owner == decl {
					printErr(message)
					return false, oself != nil
				}
				continue
			}
			if r.oself {
				oself = r
			}
			if r.owner == decl {
				printErr(message)
				return false, oself != nil
			}
		}
		return true, oself != nil
	}

	// Returns referencer by case.
	// It may be returns nil.
	// This should be used only for safe places, when absolutely no cycles.
	fn getReferencer(mut *self): &referencer {
		mut r := self.referencer
		for r != nil; r = r.prev {
			// If oself is true, return nil referencer.
			// Because there is no risk for type aliases and other things.
			// Just safe. Do not track references, no risk for cycles.
			if r.oself {
				return nil
			}
		}
		return self.referencer
	}

	fn checkIllegalCycles(mut *self, name: &token::Token, mut decl: any): (ok: bool) {
		return self.isIllegalCycleSafe(name, decl, self.cycleErr&cycleErrDisable == 0)
	}

	fn isIllegalCycleSafe(mut *self, name: &token::Token, mut decl: any, err: bool): (ok: bool) {
		self.cycleErr &= ^cycleErrFail // clear the cycleErrFail flag for the new analysis
		if self.referencer == nil {
			return true
		}

		match type decl {
		| &StructIns:
			s := decl.(&StructIns)
			if s.Decl != nil && s.Decl.Extern {
				return true
			}
		| &TypeAlias:
			if decl.(&TypeAlias).Extern {
				return true
			}
		}

		// Check illegal cycle for itself.
		{
			mut itself := false
			if self.referencer.oself {
				match type decl {
				| &TypeAlias:
					itself = self.referencer.owner == decl
				}
			} else {
				itself = self.referencer.owner == decl
			}
			if itself {
				if err {
					self.pushErr(name, "illegal cycle in declaration: @ refers to itself", self.referencer.name)
				}
				self.cycleErr |= cycleErrFail
				return false
			}
		}

		mut message := strings::Builder{}
		ok, oselfExist := self.checkCrossCycle(decl, &message)
		if !ok {
			if err {
				self.pushErr(name, "illegal cross cycle in declaration:\n"+message.String())
			}
			self.cycleErr |= cycleErrFail
			return false
		}

		// Append to structure depend collection if oself is not exist.
		// If oself exist, it means type is not plain.
		if !oselfExist {
			mut s, (ok) := self.referencer.owner.(&StructIns)
			if ok && s.Source == nil { // Play safe, ignore strict type alias structures.
				mut ds, (ok) := decl.(&StructIns)
				// Play safe, ignore strict type alias structures.
				if ok && ds.Source == nil && !s.Decl.depended(ds.Decl) {
					s.Decl.Depends = append(s.Decl.Depends, ds.Decl)
				}
			}
		}

		return true
	}

	fn fromTypeAlias(mut *self, mut decl: &token::Token, mut ta: &TypeAlias): Kind {
		if !self.s.isAccessibleDefine(ta.Public, ta.Token) {
			self.pushErr(decl, "undefined: "+decl.Kind)
			return nil
		}

		ta.Used = true

		{
			ok := self.checkIllegalCycles(decl, ta)
			if !ok && self.cycleErr&cycleErrDisable == 0 {
				return nil
			}
		}

		// Build kind if not built already.
		// If this type alias is checking now, do not check again.
		if ta.TypeSym.Type == nil {
			// Use self.referencer instead of getReferencer.
			// Because we have to catch type alias cycles if exist.
			// So, do not use possible nil referencer.
			ok := self.s.checkTypeAliasDecl(ta, self.referencer, self.lookup)
			if !ok {
				return nil
			}
		}

		if ta.Strict && self.s.step&stepImplsImplemented != 0 {
			// Check strict type structure if impl statements are implemented.
			// But do not check if source type is nil, it means type type alias is still checking.
			mut s := ta.TypeSym.Type.SoftStruct()
			if s.Source != nil && !s.checked {
				ok := self.checkStructIns(s, decl)
				if !ok {
					return nil
				}
			}
		}

		mut tk := &Type{
			Provider: ta.Name,
			Generic:  ta.Generic,
			Kind:     ta.TypeSym.Type.Kind,
		}

		// Handle generic strict type alias structure instances.
		// They are must be instantiated and the source instance is a placeholder.
		// Do not mutate it, never. Allocate a new instance, and handle it.
		if len(ta.Generics) > 0 {
			tk.Kind = ta.TypeSym.Type.Kind.(&StructIns).Decl.instance()
		} else {
			self.pushReferenceByKind(tk)
		}
		return tk
	}

	fn fromEnum(mut *self, decl: &token::Token, mut e: &Enum): &Enum {
		if !self.s.isAccessibleDefine(e.Public, e.Token) {
			self.pushErr(decl, "undefined: "+decl.Kind)
			return nil
		}
		return e
	}

	fn fromTypeEnum(mut *self, decl: &token::Token, mut e: &TypeEnum): &TypeEnum {
		if !self.s.isAccessibleDefine(e.Public, e.Token) {
			self.pushErr(decl, "undefined: "+decl.Kind)
			return nil
		}
		return e
	}

	fn fromTrait(mut *self, decl: &token::Token, mut t: &Trait): &Trait {
		if !self.s.isAccessibleDefine(t.Public, t.Token) {
			self.pushErr(decl, "undefined: "+decl.Kind)
			return nil
		}
		self.pushTA(taMutable)
		self.pushReference(t)
		return t
	}

	fn checkStructIns(mut *self, mut ins: &StructIns, mut errorToken: &token::Token): (ok: bool) {
		if ins.checked {
			return true
		}
		ins.checked = true
		// Break algorithm cycle.
		if self.referencer != nil && self.referencer.owner == ins.Decl {
			return true
		}
		// Do not evaluate generic methods immediately. Just precheck.
		// Otherwise type issues may occur. For example:
		//
		//	struct Bar[T]{}
		//	struct Baz[T]{}
		//
		//	struct Foo[T] {
		//		br: Bar[T]
		//		bz: Baz[T]
		//	}
		//
		//	In this example code above, we assume Bar uses Foo's bz field, which is Baz.
		//	If generic method will be checked here immediately, the Foo's bz field's type
		//	may not be evaluated here. Because durint evaluation of Bar[T],
		//	it will refer to the bz field, which is not evaluated yet.
		//	So, do not evaluate to avoid this issue. End of the semantic analysis,
		//	algorithm should check all instances gether.
		//
		// Enable generic struct collection if instance coming from different package.
		// Collect them and other relevant dependencies for deferred analysis.
		// The deferred analysis is mandatory for this kind of generic defines,
		// because this package analysis will not check them, so we have to collect
		// them for deferred check analysis.
		gstructs := self.s.meta.flags&semametaGstruct != 0
		if self.s != ins.Decl.sema && len(ins.Decl.Generics) > 0 {
			self.s.meta.flags |= semametaGstruct
		}

		// If instance is generic strict type alias.
		// Resolve the source type using resolved generics.
		if len(ins.Generics) > 0 && ins.Decl.alias != nil {
			mut typ := ins.Decl.alias.TypeSym.Type // Save placeholder type.
			ins.Decl.alias.TypeSym.Type.Kind = ins // Use instance as placeholder, to resolve source type to it.
			ok = self.s.basicStructEnvironment(ins, fn|mut sema| {
				return unsafe { self.s.checkTypeAliasDeclKind(ins.Decl.alias, ins.env.generics, nil, sema) }
			})
			ins.Decl.alias.TypeSym.Type = typ // Restore placeholder type.
			if !ok {
				return false
			}
		}

		ok = self.s.precheckStructIns(ins, self.getReferencer(), errorToken)
		if ok && len(ins.Decl.Generics) > 0 {
			// If gstruct collection mode already enabled for this sema,
			// just push this instance into the collection.
			// Otherwise, this semantic analysis process is the root gstruct collector.
			// Check collected generic structures waiting for deferred analysis.
			if gstructs {
				self.s.meta.gstructs = append(self.s.meta.gstructs, ins)
			} else if self.s != ins.Decl.sema { // Avoid checking generic defines of this sema.
				// Save current gstructs for analyais and remove the shared gstruct collection.
				// They will be checked with our local copy.
				// Then disable gstruct collection.
				//
				// This is a crucial step. Because if we use gstruct collection mode
				// enabled during gstruct analysis, they may append new instances
				// to the collection. But actually, we collected all needed
				// gstruct instances for the current (ins) main structure instance.
				// So clear the data, disable the gstruct collection mode.
				// Thus, other semas can use gstruct collection mode properly.
				// Otherwise, we have to analysis gstruct collection,
				// even with the new possible items for different main instance analysis.
				mut collectedGstructs := self.s.meta.gstructs
				self.s.meta.gstructs = nil
				self.s.meta.flags &= ^semametaGstruct

				// Before the checking main structure, check gstructs, if any.
				// Because the main structure depends to them.
				//
				// We can check structures using the current sema.
				// The checkStructIns method will check structure instance in
				// its environment and errors will be reflected to this sema.
				for (_, mut gins) in collectedGstructs {
					self.s.checkStructIns(gins)
				}

				// Check the main structure.
				self.s.checkStructIns(ins)
			} else if ins.Decl.checked {
				// gstruct collection is not enable and semas are same.
				// So this structure is instantiated in the it's own package.
				// Check it immediately, otherwise some defines may remain unchecked.
				// If this structure is already checked by the semantic analysis,
				// but instantiated by a another generic define, it will not be checked.
				// Because semantic analysis already advance to another structure.
				// To avoid this issue, check the instance here.
				self.s.checkStructIns(ins)
			}
		}
		return
	}

	// Returns whether instantiation cycle catch analysis required.
	// Also returns allowed generic type alias identifiers.
	// The identifier slice will not include method generics, if any.
	// Because we can't know exactly there is no cycle risk with no more analysis.
	// Keep it simple.
	fn inscatchNeeded(mut *self, mut s: &Struct): (yes: bool, letGenerics: []&ast::Generic) {
		if len(s.Generics) == 0 {
			return false, nil
		}
		if s.alias != nil {
			return true, s.Generics
		}
		mut sc, mut ok := self.lookup.(&scopeChecker)
		if ok {
			root := sc.getHardRoot()
			yes = root != nil && root.owner != nil &&
				root.owner.Decl != nil && root.owner.Decl.Owner == s
			if yes {
				letGenerics = s.Generics
			}
			return
		}
		mut r := self.referencer
		for r != nil; r = r.prev {
			si, (ok) := r.owner.(&StructIns)
			if ok && si.Decl == s {
				return true, s.Generics
			}
		}
		return false, nil
	}

	// Builds generic types and associates with struct s.
	// Returns struct s if no error occurred, otherwise returns nil.
	fn getStructInsWithGenerics(mut *self, mut s: &StructIns, mut indx: &ast::IndexExpr): (&StructIns, recheckNeeded: bool) {
		inscatch, letGenerics := self.inscatchNeeded(s.Decl)

		// Save configuration.
		mut referencer := self.referencer
		self.referencer = nil
		defer { self.referencer = referencer }

		// Always allow built-in defines here, because we may need to use them
		// for generic types. Restore current state after evaluation of generics.
		disBuiltin := self.disBuiltin
		self.disBuiltin = false
		defer { self.disBuiltin = disBuiltin }

		// Use rootLookup to parse generics with root lookup.
		mut lookup := self.lookup
		self.lookup = self.rootLookup
		defer { self.lookup = lookup }

		// Whether the instance pushed to recheck stack.
		mut &_recheck := &recheckNeeded // For closure.

		pushGenericToIns := fn(mut typDecl: &ast::Expr): bool {
			mut typ := unsafe { self.checkDecl(typDecl) }
			if typ == nil {
				return false
			}
			// Catch initiation cycles here if needed.
			// If type is a type alias (strict or soft), it can cause cycle.
			// Handle them here and avoid to be in cycle.
			// If struct refers to itself in generics, it causes endless instantiatation.
			if inscatch {
				ks := typ.Struct()
				if ks != nil && ks.Decl == s.Decl {
					idt, ok := typDecl.Data.(&ast::NameExpr)
					// If generic type is based identifier. Check if it's one of
					// self generic types. If so, there is no cycle risk.
					if ok {
						for _, lg in letGenerics {
							if lg.Name == idt.Name {
								goto Ok
							}
						}
					}
					unsafe { self.pushErr(typDecl.Token, "initiation cycle caused by a type declaration") }
					return false
				}
			Ok:
			}
			// Insert type to recheck collection if recheck needed.
			if unsafe { !*_recheck && len(self.ignoreGenerics) > 0 } {
				prim := typ.Prim()
				if prim != nil && unsafe { self.isIgnoredGeneric(prim.Kind) } {
					unsafe { *_recheck = true }
				}
			}
			s.Generics = append(s.Generics, &InsGeneric{Type: typ})
			return true
		}

		// Build generics.
		match type indx.Index.Data {
		| &ast::TupleExpr:
			mut tup := indx.Index.Data.(&ast::TupleExpr)
			s.Generics = make([]&InsGeneric, 0, len(tup.X))
			for (_, mut typDecl) in tup.X {
				ok := pushGenericToIns(typDecl)
				if !ok {
					return nil, false
				}
			}
		|:
			ok := pushGenericToIns(indx.Index)
			if !ok {
				return nil, false
			}
		}
		return s, recheckNeeded
	}

	fn buildStructInsWithGenerics(mut *self, mut s: &StructIns, mut indx: &ast::IndexExpr): (&StructIns, recheckNeeded: bool) {
		s, recheckNeeded = self.getStructInsWithGenerics(s, indx)
		if s == nil {
			return nil, false
		}
		mut ok := self.s.checkGenericQuantity(len(s.Decl.Generics), len(s.Generics), indx.X.Token)
		if !ok {
			return nil, false
		}
		// If recheck needed for the structure, do not build instance.
		// Avoid appending to collection, otherwise we may have duplicate instances.
		// For example:
		//
		//	consider this function:
		//		fn Foo(): Bar[T]
		//
		//	consider this code:
		//		x := int(10)
		//		Foo(x)
		//		Foo(x)
		//
		//	In this case, Foo called with type inferred generics.
		//	We build for the non-generic types first.
		//	If we append instance for Bar[T], we will have duplicate instances.
		//	Because Bar[T] will resolved as Bar[int] in the first call.
		//	The second will append Bar[T] to collection again, because there is no Bar[T].
		//	Then the new Bar[T] will resolved as Bar[int], as a result we have two Bar[int].
		//	This may also cause some conflicts, since lookup returns the first match.
		//
		// As explained above, we should not append instances into collection here.
		// Return with s directly, and report recheck needed.
		// Append instance into collection when analysis sent type to recheck.
		if recheckNeeded {
			return s, recheckNeeded
		}
		return self.buildStructIns(s, indx.X.Token), false
	}

	fn buildStructIns(mut *self, mut s: &StructIns, mut errToken: &token::Token): &StructIns {
		s = self.fromStructIns(s, errToken)
		if s != nil {
			if !s.Comparable {
				self.pushTA(taNotComparable)
			}
			if s.Mutable {
				self.pushTA(taMutable)
			}
			ok := self.checkIllegalCycles(errToken, s)
			if !ok && self.cycleErr&cycleErrDisable == 0 {
				return nil
			}
		}
		return s
	}

	// Checks structure instance.
	fn _fromStructIns(mut *self, mut ins: &StructIns, mut token: &token::Token): (ok: bool) {
		ok = self.checkStructIns(ins, token)
		if ok {
			self.pushReference(ins)
		}
		return
	}

	// Calls _fromStructIns and returns the instance if the instance is new,
	// otherwise returns the exist instance.
	fn fromStructIns(mut *self, mut ins: &StructIns, mut token: &token::Token): &StructIns {
		mut existInstance := ins.Decl.appendInstance(ins)
		if existInstance != nil {
			if !self.s.checkConstraintsStruct(ins, token, existInstance) {
				return nil
			}
			// Already checked instance, did not appended.
			// So, this instance is not unique.
			self.pushReference(existInstance)
			return existInstance
		}
		self._fromStructIns(ins, token)
		return ins
	}

	fn fromStruct(mut *self, mut decl: &token::Token, mut s: &Struct): &StructIns {
		if !self.s.isAccessibleDefine(s.Public, s.Token) {
			self.pushErr(decl, "undefined: "+decl.Kind)
			return nil
		}

		// Name selection.
		// Return instance instantly.
		if self.selection {
			return &StructIns{
				Decl: s,
			}
		}

		return s.instance()
	}

	// Returns identifier if found. Also checks founded identifier.
	// Uses internal lookup for all process except finding step of identifier.
	// Will find identifier in [l], not internal lookup.
	// Also finds in built-in lookup if allowed.
	// If another lookup nedeed, uses internal lookup, so any generic type build
	// process will use internal lookup. This might be useful for building
	// genericed type from another package.
	fn getDef(mut *self, mut decl: &token::Token, _extern: bool): Kind {
		if self.isIgnoredGeneric(decl.Kind) {
			return buildPrimType(decl.Kind)
		}

		for (_, mut g) in self.useGenerics {
			if g.Name == decl.Kind {
				// If generic type is a struct, check illegal cycles here.
				// Because generic types are evaluated without referencer.
				// So, any dependency will not be collected for structures.
				// Also, type is already evaluated, so we have to check cycle risks.
				// Because type analysis will return the evaluated type immediately.
				// Cycle analysis required types should be handled here separately.
				//
				// Type aliases or type enums will not be handled,
				// because there is no risk for type cycles.
				mut st := g.TypeSym.Type.Struct()
				if st != nil {
					ok := self.checkIllegalCycles(decl, st)
					if !ok && self.cycleErr&cycleErrDisable == 0 {
						return nil
					}
				}
				return g.TypeSym.Type.Kind
			}
		}

		if !_extern {
			mut e := self.lookup.FindEnum(decl.Kind)
			if e != nil {
				return self.fromEnum(decl, e)
			}

			mut te := self.lookup.FindTypeEnum(decl.Kind)
			if te != nil {
				return self.fromTypeEnum(decl, te)
			}

			mut t := self.lookup.FindTrait(decl.Kind)
			if t != nil {
				return self.fromTrait(decl, t)
			}
		} else if self.selection {
			self.pushErr(decl, "external types are not allowed in this scope")
			return nil
		}

		mut s := self.lookup.FindStruct(decl.Kind, _extern)
		if s != nil {
			return self.fromStruct(decl, s)
		}

		mut ta := self.lookup.FindTypeAlias(decl.Kind, _extern)
		if ta == nil && !self.disBuiltin {
			ta = findBuiltinTypeAlias(decl.Kind)
			if ta != nil && ta.Name == types::Any {
				self.pushTA(taMutable)
			}
		}
		if ta != nil {
			return self.fromTypeAlias(decl, ta)
		}

		self.pushErr(decl, "undefined: "+decl.Kind)
		return nil
	}

	fn buildName(mut *self, mut decl: &token::Token, _extern: bool): Kind {
		return self.getDef(decl, _extern)
	}

	fn buildSptrFromType(mut *self, mut valueTyp: &Type): &Sptr {
		// Check special cases.
		match {
		| valueTyp == nil:
			return nil
		| valueTyp.Array() != nil && valueTyp.Array().Auto:
			self.pushErr(self.errorToken, "auto-sized arrays are not allowed as value type")
			return nil
		}
		return &Sptr{
			Value: valueTyp,
		}
	}

	fn __buildSptr(mut *self, mut decl: &ast::UnaryExpr): &Sptr {
		self.pushTA(taMutable)

		disableTA := self.disableTA
		self.disableTA |= taMutable | taNotComparable
		defer { self.disableTA = disableTA }

		mut valueTyp := self.checkDecl(decl.X)
		return self.buildSptrFromType(valueTyp)
	}

	fn buildSptr(mut *self, mut decl: &ast::UnaryExpr): &Sptr {
		if self.referencer != nil {
			oself := self.referencer.oself
			self.referencer.oself = true
			mut typ := self.__buildSptr(decl)
			self.referencer.oself = oself
			return typ
		}
		return self.__buildSptr(decl)
	}

	fn __buildChan(mut *self, mut decl: &ast::ChanType): &Chan {
		// Do not disable mutability analysis.
		// Element type of channel is directly affects the mutability of channel.
		disableTA := self.disableTA
		self.disableTA |= taNotComparable
		defer { self.disableTA = disableTA }

		mut valueTyp := self.checkDecl(decl.Value)
		if valueTyp == nil {
			return nil
		}
		self.pushRuntimeImpl("pchan", decl.Value.Token, valueTyp)
		if self.disableTA&taMutable == 0 && valueTyp.Mutable() {
			self.pushTA(taMutable)
		}
		return &Chan{
			Recv:  decl.Dir&ast::RECV != 0,
			Send:  decl.Dir&ast::SEND != 0,
			Value: valueTyp,
		}
	}

	fn buildChan(mut *self, mut decl: &ast::ChanType): &Chan {
		if self.referencer != nil {
			oself := self.referencer.oself
			self.referencer.oself = true
			mut typ := self.__buildChan(decl)
			self.referencer.oself = oself
			return typ
		}
		return self.__buildChan(decl)
	}

	fn buildPtrFromType(mut *self, mut valueTyp: &Type): &Ptr {
		// Check special cases.
		match {
		| valueTyp == nil:
			return nil
		| valueTyp.Array() != nil && valueTyp.Array().Auto:
			self.pushErr(self.errorToken, "auto-sized arrays are not allowed as value type")
			return new(Ptr)
		}

		return &Ptr{
			Value: valueTyp,
		}
	}

	fn __buildPtr(mut *self, mut decl: &ast::UnaryExpr): &Ptr {
		self.pushTA(taMutable)

		disableTA := self.disableTA
		self.disableTA |= taMutable | taNotComparable
		defer { self.disableTA = disableTA }

		mut valueTyp := (&Type)(nil)

		if !decl.IsUnsafePtr() {
			valueTyp = self.checkDecl(decl.X)
			return self.buildPtrFromType(valueTyp)
		}

		return &Ptr{
			Value: valueTyp,
		}
	}

	fn buildPtr(mut *self, mut decl: &ast::UnaryExpr): &Ptr {
		if self.referencer != nil {
			oself := self.referencer.oself
			self.referencer.oself = true
			mut typ := self.__buildPtr(decl)
			self.referencer.oself = oself
			return typ
		}
		return self.__buildPtr(decl)
	}

	fn __buildSlice(mut *self, mut decl: &ast::SliceType): &Slice {
		self.pushTA(taNotComparable | taMutable)

		disableTA := self.disableTA
		self.disableTA |= taMutable | taNotComparable
		defer { self.disableTA = disableTA }

		mut valueTyp := self.checkDecl(decl.Value)

		// Check special cases.
		match {
		| valueTyp == nil:
			return nil
		| valueTyp.Array() != nil && valueTyp.Array().Auto:
			self.pushErr(decl.Value.Token, "auto-sized arrays are not allowed as value type")
			return nil
		}

		return &Slice{
			Value: valueTyp,
		}
	}

	fn buildSlice(mut *self, mut decl: &ast::SliceType): &Slice {
		if self.referencer != nil {
			oself := self.referencer.oself
			self.referencer.oself = true
			mut typ := self.__buildSlice(decl)
			self.referencer.oself = oself
			return typ
		}
		return self.__buildSlice(decl)
	}

	fn buildArray(mut *self, mut decl: &ast::ArrayType): &Array {
		mut n := 0
		if !decl.IsAutoSized() {
			mut size := self.s.eval(self.lookup).evalExpr(decl.Size, evalDefault|evalPhysicalMem|evalUnwrapUntyped)
			if size == nil {
				return nil
			}

			if !size.IsConst() {
				self.pushErr(decl.Size.Token, "expression must be constant")
				return nil
			} else if size.Type.Prim() == nil || !types::IsInt(size.Type.Prim().Kind) {
				self.pushErr(decl.Size.Token, "array size must be integer")
				return nil
			}

			n = int(size.Constant.AsI64())
			if n < 0 {
				self.pushErr(decl.Value.Token, "array size must be positive")
				return nil
			} else {
				max := types::MaxI(types::Int)
				if types::BitSize != 64 && i64(n) > max {
					self.pushErr(decl.Size.Token, "array size @ overflows the comptime-defined limit of @",
						size.Constant.String(), conv::FormatInt(max, 10))
					return nil
				}
			}
		}

		// Do not disable mutability and comparable analysis.
		// Element type of array is directly affects the mutability and comparability of array.
		mut valueTyp := self.checkDecl(decl.Value)

		// Check special cases.
		match {
		| valueTyp == nil:
			return nil
		| valueTyp.Array() != nil && valueTyp.Array().Auto:
			self.pushErr(decl.Value.Token, "auto-sized arrays are not allowed as value type")
			return nil
		}

		if self.disableTA&taNotComparable == 0 && !valueTyp.Comparable() {
			self.pushTA(taNotComparable)
		}
		if self.disableTA&taMutable == 0 && valueTyp.Mutable() {
			self.pushTA(taMutable)
		}

		return &Array{
			Auto:  decl.IsAutoSized(),
			N:     n,
			Value: valueTyp,
		}
	}

	fn __buildMap(mut *self, mut decl: &ast::MapType): &Map {
		// Evaluate key type like no cycle risk, do not log errors about it.
		// We have to do this for checking correct map type dependencies,
		// cycle types are prevents valid map key types. So, catch them but
		// do not log as cycle error, log as invalid key type error.
		cycleErr := self.cycleErr
		self.cycleErr &= ^cycleErrFail
		self.cycleErr |= cycleErrDisable

		mut keyTyp := self.checkDecl(decl.Key)
		if keyTyp == nil {
			self.cycleErr = cycleErr
			return nil
		}
		// Check whether key type is valid.
		// It should be comparable, if cycle analysis failed, we have cycles,
		// so we have a map type (this type, actually), so it is not comparable.
		if self.cycleErr&cycleErrFail != 0 || !keyTyp.Comparable() {
			self.cycleErr = cycleErr
			self.s.pushErr(decl.Key.Token, "type @ does not match constraint of Key: @", keyTyp.String(), constraintComparable)
			return nil
		}
		self.cycleErr = cycleErr

		// Evaluate value type with no cycle risk.
		mut valueTyp := self.checkDecl(decl.Value)
		if valueTyp == nil {
			return nil
		}
		if valueTyp.Enum() != nil {
			self.pushErr(decl.Value.Token, "enum types are not supported as map-key")
		}

		self.pushRuntimeImpl("hmap", decl.Key.Token, keyTyp, valueTyp)

		if self.disableTA&taMutable == 0 && (keyTyp.Mutable() || valueTyp.Mutable()) {
			self.pushTA(taMutable)
		}

		return &Map{
			Key:   keyTyp,
			Value: valueTyp,
		}
	}

	fn buildMap(mut *self, mut decl: &ast::MapType): &Map {
		self.pushTA(taNotComparable)

		// Do not disable mutability analysis.
		// Key and Value type of map is directly affects the mutability of map.
		disableTA := self.disableTA
		self.disableTA |= taNotComparable
		defer { self.disableTA = disableTA }

		if self.referencer != nil {
			oself := self.referencer.oself
			self.referencer.oself = true
			mut typ := self.__buildMap(decl)
			self.referencer.oself = oself
			return typ
		}
		return self.__buildMap(decl)
	}

	fn buildTuple(mut *self, mut decl: &ast::TupleExpr): &Tuple {
		mut types := make([]&Type, 0, len(decl.X))
		for (_, mut t) in decl.X {
			mut kind := self.checkDecl(t)
			if kind == nil {
				return nil
			}
			types = append(types, kind)
		}

		return &Tuple{Types: types}
	}

	fn checkFuncTypes(mut *self, mut f: &FuncIns): (ok: bool) {
		for (_, mut p) in f.Params {
			p.Type = self.checkDecl(p.Decl.TypeSym.Decl)
			ok = p.Type != nil
			if !ok {
				return false
			}
			self.s.checkFuncParamKind(p)
		}

		if !f.Decl.IsVoid() {
			f.Result = self.checkDecl(f.Decl.Result.TypeSym.Decl)
			return f.Result != nil
		}

		return true
	}

	fn __buildFunc(mut *self, mut decl: &ast::Func): &FuncIns {
		self.pushTA(taNotComparable)

		disableTA := self.disableTA
		self.disableTA |= taMutable | taNotComparable
		defer { self.disableTA = disableTA }

		if len(decl.Generics) > 0 {
			self.pushErr(decl.Token, "genericed functions cannot be anonymous")
			return nil
		}

		mut f := buildFunc(decl)

		n := len(self.s.errors)
		self.s.checkAnonFuncDecl(f)
		if n != len(self.s.errors) {
			return nil
		}

		mut ins := f.instanceForce()
		ins.Anon = true
		ins.AsAnon = true
		ins.reloaded = true

		ok := self.checkFuncTypes(ins)
		if !ok {
			return nil
		}

		return ins
	}

	fn buildFunc(mut *self, mut decl: &ast::Func): &FuncIns {
		if self.referencer != nil {
			oself := self.referencer.oself
			self.referencer.oself = true
			mut typ := self.__buildFunc(decl)
			self.referencer.oself = oself
			return typ
		}
		return self.__buildFunc(decl)
	}

	fn buildNamespace(mut *self, mut ns: &ast::NamespaceExpr): Kind {
		mut imp := findNamespace(self.lookup, ns.Namespace.Kind)
		if imp == nil || !imp.isLookupable() {
			self.pushErr(ns.Namespace, "undefined namespace: "+ns.Namespace.Kind)
			return nil
		}

		disableTA := self.disableTA
		self.disableTA |= taMutable | taNotComparable
		defer { self.disableTA = disableTA }

		self.disallowBuiltin()
		mut lookup := self.lookup
		self.lookup = imp
		mut kind := self.buildName(ns.Name, false)
		self.lookup = lookup
		self.allowBuiltin()
		return kind
	}

	fn buildIndex(mut *self, mut indx: &ast::IndexExpr): (Kind, recheckNeeded: bool) {
		mut typ := self.build(indx.X.Data)
		if typ == nil {
			return nil, false
		}
		mut s := typ.SoftStruct()
		if self.selection {
			self.pushErr(indx.X.Token, "generics are not allowed in this scope")
			return nil, false
		}
		if s == nil || s.Source != nil || len(s.Generics) > 0 {
			self.pushErr(indx.X.Token, "type @ does not supports generics or already instantiated", typ.String())
			return nil, false
		}
		return self.buildStructInsWithGenerics(s, indx)
	}

	fn build(mut *self, mut declKind: ast::ExprData): &Type {
		let mut kind: Kind = nil
		let mut recheckNeeded: bool = false
		match type declKind {
		| &ast::RangeExpr:
			mut r := declKind.(&ast::RangeExpr)
			return self.build(r.X.Data)
		| &ast::NameExpr:
			mut name := declKind.(&ast::NameExpr)
			mut t := self.buildName(name.Token, name.Extern)
			if t != nil {
				kind = t
			}
		| &ast::ChanType:
			mut t := self.buildChan(declKind.(&ast::ChanType))
			if t != nil {
				kind = t
			}
		| &ast::UnaryExpr:
			mut u := declKind.(&ast::UnaryExpr)
			match u.Op.ID {
			| token::MUL:
				mut t := self.buildPtr(u)
				if t != nil {
					kind = t
				}
			| token::AND:
				mut t := self.buildSptr(u)
				if t != nil {
					kind = t
				}
			|:
				self.pushErr(self.errorToken, "invalid type")
				return nil
			}
		| &ast::SliceType:
			mut t := self.buildSlice(declKind.(&ast::SliceType))
			if t != nil {
				kind = t
			}
		| &ast::ArrayType:
			mut t := self.buildArray(declKind.(&ast::ArrayType))
			if t != nil {
				kind = t
			}
		| &ast::MapType:
			mut t := self.buildMap(declKind.(&ast::MapType))
			if t != nil {
				kind = t
			}
		| &ast::TupleExpr:
			mut t := self.buildTuple(declKind.(&ast::TupleExpr))
			if t != nil {
				kind = t
			}
		| &ast::Func:
			mut t := self.buildFunc(declKind.(&ast::Func))
			if t != nil {
				kind = t
			}
		| &ast::NamespaceExpr:
			mut t := self.buildNamespace(declKind.(&ast::NamespaceExpr))
			if t != nil {
				kind = t
			}
		| &ast::IndexExpr:
			mut t, (recheckNeeded) := self.buildIndex(declKind.(&ast::IndexExpr))
			if t != nil {
				kind = t
			}
		|:
			self.pushErr(self.errorToken, "invalid type")
			return nil
		}
		if kind == nil {
			return nil
		}
		mut typ := (&Type)(nil)
		match type kind {
		| &Type:
			typ = kind.(&Type)
		|:
			typ = &Type{Kind: kind}
			if self.ignoredGenerics != nil {
				_, prim := kind.(&Prim)
				if prim {
					unsafe { *self.ignoredGenerics = append(*self.ignoredGenerics, typ) }
				}
			}
		}
		// Recheck needed, append type into collection.
		if recheckNeeded {
			unsafe { *self.recheckNeed = append(*self.recheckNeed, typ) }
		}
		return typ
	}

	fn checkDecl(mut *self, mut decl: &ast::Expr): &Type {
		mut errorToken := self.errorToken
		defer { self.errorToken = errorToken }
		self.errorToken = decl.Token

		mut typ := self.build(decl.Data)
		if typ != nil {
			mut s, _ := typ.Kind.(&StructIns)
			if s != nil && !self.selection {
				if !self.s.checkGenericQuantity(len(s.Decl.Generics), len(s.Generics), self.errorToken) {
					return nil
				}
				// If there is no generics and it passes the generics analysis,
				// it is just an instance and needs to be checked.
				if len(s.Generics) == 0 {
					s = self.buildStructIns(s, self.errorToken)
					if s == nil {
						return nil
					}
					typ.Kind = s
				}
			}
		}

		return typ
	}

	fn check(mut *self, mut t: &TypeSym) {
		if t.Decl == nil {
			return
		}
		mut kind := self.checkDecl(t.Decl)
		if kind == nil {
			t.removeKind()
			return
		}
		t.Type = kind
	}

	// Rechecks structure instance.
	// Updates s to common instance before return.
	fn recheckStructIns(mut *self, mut &s: *&StructIns, mut errorToken: &token::Token): (ok: bool) {
		(*s).checked = false

		// We need to hard-check methods, if it have any method.
		// Because method types will not be rechecked with the recheck strategy.
		// So if any method refers to generic type, it may use unresolved type.
		// Reload (resolve) types from scratch.
		for (_, mut m) in (*s).Methods {
			// If method have parameters (except receiver) or have result type,
			// then reload types. Otherwise, it is not needed.
			if len(m.Params) > 1 || !m.IsVoid() {
				for (_, mut mm) in m.Instances {
					ok = self.s.reloadFuncInsTypes(mm)
				}
			}
		}

		// Recheck needed types will not be appended.
		// So append instance to the collection. The buildStructIns will do it.
		// Now, the instance s have resolved types completely.
		// There is no risk for duplicated instances. Time to append.
		//
		// The buildStructIns returns common instance to avoid using duplicated instances.
		// So the returned instance may be already existing or the same instance we pass.
		// In both cases, use the result to make sure we have common instance.
		*s = self.buildStructIns(*s, errorToken)
		// The result instance is not nil, so analysis were successful.
		ok = *s != nil
		return
	}

	// Rechecks the recheckable type.
	// See developer reference (15).
	fn recheck(mut *self, mut t: recheckableType, mut errorToken: &token::Token): (ok: bool) {
		match type t {
		| &Type:
			mut typ := t.(&Type)
			match {
			| typ.Struct() != nil:
				mut s := typ.Struct()
				ok = self.recheckStructIns(&s, errorToken)
				// Analysis returned successfully.
				// Update typ.Kind with the instance s to make sure using common instance.
				// Because all types must be point to the same common instance.
				if ok {
					typ.Kind = s
				}
			|:
				panic("unreachable")
			}
		| &StructIns:
			mut s := t.(&StructIns)
			return self.recheckStructIns(&s, errorToken)
		}
		return
	}
}

// Identifier lookup in type.
struct identTypeLookup{}

impl identTypeLookup {
	fn prim(name: string, t: &Prim): bool {
		return t.Kind == name
	}

	fn exist(name: string, mut k: &Type): bool {
		match {
		| k.Prim() != nil:
			return identTypeLookup.prim(name, k.Prim())
		| k.Chan() != nil:
			mut ch := k.Chan()
			return identTypeLookup.exist(name, ch.Value)
		| k.Sptr() != nil:
			mut sptr := k.Sptr()
			return identTypeLookup.exist(name, sptr.Value)
		| k.Ptr() != nil:
			mut ptr := k.Ptr()
			return identTypeLookup.exist(name, ptr.Value)
		| k.Slice() != nil:
			mut slc := k.Slice()
			return identTypeLookup.exist(name, slc.Value)
		| k.Array() != nil:
			mut arr := k.Array()
			return identTypeLookup.exist(name, arr.Value)
		| k.Map() != nil:
			mut m := k.Map()
			return identTypeLookup.exist(name, m.Key) ||
				identTypeLookup.exist(name, m.Value)
		| k.Struct() != nil:
			mut s := k.Struct()
			for (_, mut g) in s.Generics {
				if identTypeLookup.exist(name, g.Type) {
					return true
				}
			}
			return false
		| k.Func() != nil:
			mut f := k.Func()
			for (_, mut p) in f.Params {
				if p.Decl.IsSelf() {
					continue
				}
				if identTypeLookup.exist(name, p.Type) {
					return true
				}
			}
			if f.Result != nil {
				return identTypeLookup.exist(name, f.Result)
			}
			return false
		| k.Tuple() != nil:
			mut tup := k.Tuple()
			for (_, mut t) in tup.Types {
				if identTypeLookup.exist(name, t) {
					return true
				}
			}
			return false
		|:
			return false
		}
	}
}

fn kindUsesGenerics(mut k: &Type, generics: []&ast::Generic): bool {
	for _, g in generics {
		if identTypeLookup.exist(g.Name, k) {
			return true
		}
	}
	return false
}

// Reports whether directive is exist.
fn hasDirective(mut directives: []&ast::Directive, tag: string): bool {
	for (_, mut dr) in directives {
		if dr.Tag.Kind == tag {
			return true
		}
	}
	return false
}

fn canGetPtr(mut v: &Value): bool { return v.Lvalue }

// Reports whether type has built-in string conversion support.
fn isBuiltinStrConvertible(mut t: &Type): bool {
	return !t.Void() && t.Func() == nil && t.Tuple() == nil && !t.comptime()
}

fn buildPrimType(kind: string): &Prim {
	return &Prim{
		Kind: kind,
	}
}

fn getStructFromKind(mut k: &Type): &Struct {
	match {
	| k == nil:
		return nil
	| k.Struct() != nil:
		return k.Struct().Decl
	| k.Sptr() != nil:
		return getStructFromKind(k.Sptr().Value)
	| k.Slice() != nil:
		return getStructFromKind(k.Slice().Value)
	| k.Array() != nil:
		return getStructFromKind(k.Array().Value)
	| k.Ptr() != nil:
		// Pass pointers.
		// Cloning just copies pointer address.
		// There is no any illegal cycle risk.
		return nil
	|:
		return nil
	}
}

// Reports whether type is valid for SizeOf/AlignOf functions.
fn validTypeForXof(mut t: &Type): bool {
	return !t.Void() && t.Func() == nil && t.Tuple() == nil && !t.comptime()
}

// Pseudo source type for strict type alias structure instances.
let mut pseudoSource = new(Type)

// Initializes new structure for strict types.
// See developer reference (9) for details.
fn initNewStructType(name: string, mut source: &Type): &StructIns {
	mut s := new(Struct)
	s.Name = name
	mut ins := s.instance()
	s.appendInstance(ins)
	ins.setSource(source)
	return ins
}

// Returns enum type for matching.
// Returns nil if there is no enum.
fn getMatchEnum(mut t: &Type): &Enum {
	// If type is a structure, it might be a strict type alias to an enum.
	// This is invalid for matching, wee need to pure enum type.
	if t.SoftStruct() != nil {
		return nil
	}
	return t.Enum()
}