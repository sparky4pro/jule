use "std/conv"
use "std/math/big"

// Constant data.
// Use NewNil function instead of Const{} for nil literal.
struct Const {
	Kind: string
	data: any
}

// Returns new constant value instance from big-integer.
fn NewInt(i: big::Int): &Const { return &Const{data: i} }

// Returns new constant value instance from 64-bit signed integer.
// Value will have big-integer precision.
fn NewI64(x: i64): &Const { return &Const{data: big::Int.New(x)} }

// Returns new constant value instance from 64-bit unsigned integer.
// Value will have big-integer precision.
fn NewU64(x: u64): &Const {
	let mut i: big::Int
	i.SetU64(x)
	return &Const{data: i}
}

// Returns new constant value instance from boolean.
fn NewBool(x: bool): &Const { return &Const{data: x} }

// Returns new constant value instance from string.
fn NewString(x: string): &Const { return &Const{data: x} }

// Returns new constant value instance from 64-bit floating-point.
fn NewF64(x: f64): &Const { return &Const{data: x} }

// Returns new constant value instance from 128-bit floating-point complex.
fn NewCmplx128(x: cmplx128): &Const { return &Const{data: x} }

// Returns new constant value instance with nil.
fn NewNil(): &Const { return &Const{data: nil} }

impl Const {
	//
	// Read
	//

	// Reads integer data.
	// Returns zero value if data is not integer.
	fn ReadInt(*self): big::Int {
		mut i, _ := self.data.(big::Int)
		return i
	}

	// Reads boolean data.
	// Returns false if data is not boolean.
	fn ReadBool(*self): bool {
		if !self.IsBool() {
			return false
		}
		return self.data.(bool)
	}

	// Reads string data.
	// Returns empty string if data is not string.
	fn ReadString(*self): string {
		if !self.IsString() {
			return ""
		}
		return self.data.(string)
	}

	// Reads 64-bit floating-point data.
	// Returns 0 if data is not 64-bit floating-point.
	fn ReadF64(*self): f64 {
		if !self.IsF64() {
			return 0
		}
		return self.data.(f64)
	}

	// Reads 128-bit floating-point complex data.
	// Returns 0 if data is not 128-bit floating-point complex.
	fn ReadCmplx128(*self): cmplx128 {
		if !self.IsCmplx128() {
			return 0
		}
		return self.data.(cmplx128)
	}

	//
	// Castings
	//

	// Reads data as 64-bit signed integer.
	// Returns 0 if data is string, bool or which is not numeric.
	fn AsI64(*self): i64 {
		match type self.data {
		| big::Int:
			i := self.data.(big::Int)
			if i.IsI64() {
				return i.I64()
			}
			return i64(i.U64())
		| f64:
			return i64(self.data.(f64))
		|:
			return 0
		}
	}

	// Reads data as 64-bit unsigned integer.
	// Returns 0 if data is string, bool or which is not numeric.
	fn AsU64(*self): u64 {
		match type self.data {
		| big::Int:
			i := self.data.(big::Int)
			if i.IsU64() {
				return i.U64()
			}
			return u64(i.I64())
		| f64:
			return u64(self.data.(f64))
		|:
			return 0
		}
	}

	// Reads data as 64-bit floating-point.
	// Returns 0 if data is string, bool or which is not numeric.
	fn AsF64(*self): f64 {
		match type self.data {
		| f64:
			return self.data.(f64)
		| big::Int:
			f, _ := self.data.(big::Int).F64()
			return f
		|:
			return 0
		}
	}

	// Reads data as 128-bit floating-point complex.
	// Returns 0 if data is string, bool or which is not numeric.
	fn AsCmplx128(*self): cmplx128 {
		match type self.data {
		| f64:
			return cmplx(self.data.(f64), 0)
		| big::Int:
			f, _ := self.data.(big::Int).F64()
			return cmplx(f, 0)
		| cmplx128:
			return self.data.(cmplx128)
		|:
			return 0
		}
	}

	// Sets constant value from big-integer.
	fn SetInt(mut *self, x: big::Int) { self.data = x }

	// Sets constant value from 64-bit signed integer.
	fn SetI64(mut *self, x: i64) { self.data = big::Int.New(x) }

	// Sets constant value from 64-bit unsigned integer.
	fn SetU64(mut *self, x: u64) {
		let mut i: big::Int
		i.SetU64(x)
		self.data = i
	}

	// Sets constant value from boolean.
	fn SetBool(mut *self, x: bool) { self.data = x }

	// Sets constant value from string.
	fn SetString(mut *self, x: string) { self.data = x }

	// Sets constant value from 64-bit floating-point.
	fn SetF64(mut *self, x: f64) { self.data = x }

	// Sets constant value from 128-bit floating-point complex.
	fn SetCmplx128(mut *self, x: cmplx128) { self.data = x }

	// Sets constant value to nil.
	fn SetNil(mut *self) { self.data = nil }

	// Reports whether data is integer.
	fn IsInt(*self): bool {
		_, ok := self.data.(big::Int)
		return ok
	}

	// Reports whether data is boolean.
	fn IsBool(*self): bool {
		_, ok := self.data.(bool)
		return ok
	}

	// Reports whether data is string.
	fn IsString(*self): bool {
		_, ok := self.data.(string)
		return ok
	}

	// Reports whether data is 64-bit floating-point.
	fn IsF64(*self): bool {
		_, ok := self.data.(f64)
		return ok
	}

	// Reports whether data is 128-bit floating-point complex.
	fn IsCmplx128(*self): bool {
		_, ok := self.data.(cmplx128)
		return ok
	}

	// Reports whether data is nil.
	fn IsNil(*self): bool { return self.data == nil }

	// Reports whether self and x has same type.
	fn AreSameTypes(*self, x: Const): bool {
		match {
		| self.IsInt() == x.IsInt():
			return true
		| self.IsF64() == x.IsF64():
			return true
		| self.IsCmplx128() == x.IsCmplx128():
			return true
		| self.IsBool() == x.IsBool():
			return true
		| self.IsString() == x.IsString():
			return true
		| self.IsNil() == x.IsNil():
			return true
		|:
			return false
		}
	}

	// Reports whether self and x are true.
	// Returns false if type is not supported.
	fn LAND(*self, x: Const): bool {
		match {
		| self.IsBool() && x.IsBool():
			return self.ReadBool() && x.ReadBool()
		|:
			return false
		}
	}

	// Reports whether self or x is true.
	// Returns false if type is not supported.
	fn LOR(*self, x: Const): bool {
		match {
		| self.IsBool() && x.IsBool():
			return self.ReadBool() || x.ReadBool()
		|:
			return false
		}
	}

	// Reports whether self and x are equals.
	// Returns false if type is not supported.
	fn EQL(*self, x: Const): bool {
		match {
		| self.IsNil():
			return x.IsNil()
		| self.IsBool():
			return x.IsBool() && self.ReadBool() == x.ReadBool()
		| self.IsString():
			return x.IsString() && self.ReadString() == x.ReadString()
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				return a.Cmp(&b) == 0
			}
			if a.Sign() == -1 {
				return a.I64() == x.AsI64()
			}
			return a.U64() == x.AsU64()
		| self.IsF64():
			return self.ReadF64() == x.AsF64()
		| self.IsCmplx128():
			return self.ReadCmplx128() == x.AsCmplx128()
		|:
			return false
		}
	}

	// Reports whether self less than x.
	// Returns false if type is unsupported by operation.
	//
	// Supported types are:
	//	- strings
	//	- 64-bit signed integer
	//	- 64-bit unsigned integer
	//	- 64-bit floating-point
	fn LSS(*self, x: Const): bool {
		match {
		| self.IsString():
			return x.IsString() && self.ReadString() < x.ReadString()
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				return a.Cmp(&b) == -1
			}
			if a.Sign() == -1 {
				return a.I64() < x.AsI64()
			}
			return a.U64() < x.AsU64()
		| self.IsF64():
			return self.ReadF64() < x.AsF64()
		|:
			return false
		}
	}

	// Reports whether self less than or equals to x.
	// Returns false if type is unsupported by operation.
	//
	// Supported types are:
	//	- strings
	//	- 64-bit signed integer
	//	- 64-bit unsigned integer
	//	- 64-bit floating-point
	fn LEQ(*self, x: Const): bool {
		match {
		| self.IsString():
			return x.IsString() && self.ReadString() <= x.ReadString()
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				return a.Cmp(&b) <= 0
			}
			if a.Sign() == -1 {
				return a.I64() <= x.AsI64()
			}
			return a.U64() <= x.AsU64()
		| self.IsF64():
			return self.ReadF64() <= x.AsF64()
		|:
			return false
		}
	}

	// Reports whether self greater than x.
	// Returns false if type is unsupported by operation.
	//
	// Supported types are:
	//	- strings
	//	- 64-bit signed integer
	//	- 64-bit unsigned integer
	//	- 64-bit floating-point
	fn GTR(*self, x: Const): bool {
		match {
		| self.IsString():
			return x.IsString() && self.ReadString() > x.ReadString()
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				return a.Cmp(&b) > 0
			}
			if a.Sign() == -1 {
				return a.I64() > x.AsI64()
			}
			return a.U64() > x.AsU64()
		| self.IsF64():
			return self.ReadF64() > x.AsF64()
		|:
			return false
		}
	}

	// Reports whether self greater than or equals to x.
	// Returns false if type is unsupported by operation.
	//
	// Supported types are:
	//	- strings
	//	- 64-bit signed integer
	//	- 64-bit unsigned integer
	//	- 64-bit floating-point
	fn GEQ(*self, x: Const): bool {
		match {
		| self.IsString():
			return x.IsString() && self.ReadString() >= x.ReadString()
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				return a.Cmp(&b) >= 0
			}
			if a.Sign() == -1 {
				return a.I64() >= x.AsI64()
			}
			return a.U64() >= x.AsU64()
		| self.IsF64():
			return self.ReadF64() >= x.AsF64()
		|:
			return false
		}
	}

	// Adds x's value to itself value.
	// Reports whether operation is success.
	fn ADD(mut *self, x: Const): bool {
		match {
		| self.IsString():
			if !x.IsString() {
				return false
			}
			self.SetString(self.ReadString() + x.ReadString())
		| self.IsCmplx128() || x.IsCmplx128():
			a := self.AsCmplx128()
			b := x.AsCmplx128()
			self.SetCmplx128(a + b)
		| self.IsF64():
			self.SetF64(self.ReadF64() + x.AsF64())
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				let mut r: big::Int
				r.Add(&a, &b)
				self.SetInt(r)
			} else {
				// If x is not integer, it should be float.
				if a.Sign() == -1 {
					self.SetF64(self.AsF64() + x.AsF64())
				} else {
					self.SetF64(self.AsF64() + x.AsF64())
				}
			}
		|:
			return false
		}
		return true
	}

	// Subs x's value from itself value.
	// Reports whether operation is success.
	fn SUB(mut *self, x: Const): bool {
		match {
		| self.IsF64():
			self.SetF64(self.ReadF64() - x.AsF64())
		| self.IsCmplx128() || x.IsCmplx128():
			a := self.AsCmplx128()
			b := x.AsCmplx128()
			self.SetCmplx128(a - b)
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				let mut r: big::Int
				r.Sub(&a, &b)
				self.SetInt(r)
			} else {
				// If x is not integer, it should be float.
				if a.Sign() == -1 {
					self.SetF64(self.AsF64() - x.AsF64())
				} else {
					self.SetF64(self.AsF64() - x.AsF64())
				}
			}
		|:
			return false
		}
		return true
	}

	// Multiplies x's value to c's value.
	// Reports whether operation is success.
	fn MUL(mut *self, x: Const): bool {
		match {
		| self.IsF64():
			self.SetF64(self.ReadF64() * x.AsF64())
		| self.IsCmplx128() || x.IsCmplx128():
			a := self.AsCmplx128()
			b := x.AsCmplx128()
			self.SetCmplx128(a * b)
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				let mut r: big::Int
				r.Mul(&a, &b)
				self.SetInt(r)
			} else {
				// If x is not integer, it should be float.
				if a.Sign() == -1 {
					self.SetF64(self.AsF64() * x.AsF64())
				} else {
					self.SetF64(self.AsF64() * x.AsF64())
				}
			}
		|:
			return false
		}
		return true
	}

	// Divides itself value to x's value.
	// Reports whether operation is success.
	// Reports false if divided-by-zero.
	//
	// NOTICE
	//	This operation makes constant value is floating-point.
	fn DIV(mut *self, x: Const): bool {
		match {
		| self.IsF64():
			l := x.AsF64()
			if l == 0 {
				return false
			}
			self.SetF64(self.ReadF64() / l)
		| self.IsCmplx128() || x.IsCmplx128():
			a := self.AsCmplx128()
			b := x.AsCmplx128()
			if b == 0 {
				return false
			}
			self.SetCmplx128(a / b)
		| self.IsInt():
			a := self.data.(big::Int)
			if x.IsInt() {
				b := x.data.(big::Int)
				if b.BitLen() == 0 { // b == 0
					return false
				}
				let mut tmp: big::Int
				let mut r: big::Int
				r.QuoRem(&a, &b, &tmp)
				self.SetInt(r)
			} else {
				// If x is not integer, it should be float.
				if a.Sign() == -1 {
					self.SetF64(self.AsF64() / x.AsF64())
				} else {
					self.SetF64(self.AsF64() / x.AsF64())
				}
			}
		|:
			return false
		}
		return true
	}

	// Mods itself value to x's value.
	// Reports whether operation is success.
	// Reports false if divided-by-zero.
	fn REM(mut *self, x: Const): bool {
		i, mut ok := self.data.(big::Int)
		if !ok {
			return false
		}
		xi, ok := x.data.(big::Int)
		if !ok {
			return false
		}
		let mut tmp: big::Int
		let mut r: big::Int
		tmp.QuoRem(&i, &xi, &r)
		self.SetInt(r)
		return true
	}

	// Bitwise and itself value to x's value.
	// Reports whether operation is success.
	fn AND(mut *self, x: Const): bool {
		i, mut ok := self.data.(big::Int)
		if !ok {
			return false
		}
		xi, ok := x.data.(big::Int)
		if !ok {
			return false
		}
		let mut r: big::Int
		r.And(&i, &xi)
		self.SetInt(r)
		return true
	}

	// Bitwise or itself value to x's value.
	// Reports whether operation is success.
	fn OR(mut *self, x: Const): bool {
		i, mut ok := self.data.(big::Int)
		if !ok {
			return false
		}
		xi, ok := x.data.(big::Int)
		if !ok {
			return false
		}
		let mut r: big::Int
		r.Or(&i, &xi)
		self.SetInt(r)
		return true
	}

	// Bitwise xor itself value to x's value.
	// Reports whether operation is success.
	fn XOR(mut *self, x: Const): bool {
		i, mut ok := self.data.(big::Int)
		if !ok {
			return false
		}
		xi, ok := x.data.(big::Int)
		if !ok {
			return false
		}
		let mut r: big::Int
		r.Xor(&i, &xi)
		self.SetInt(r)
		return true
	}

	// Left shifts itself value to x's value.
	// Reports whether operation is success.
	fn SHL(mut *self, x: Const): bool {
		i, mut ok := self.data.(big::Int)
		if !ok {
			return false
		}
		xi, ok := x.data.(big::Int)
		if !ok {
			return false
		}
		let mut r: big::Int
		r.Lsh(&i, uint(xi.U64()))
		self.SetInt(r)
		return true
	}

	// Right shifts itself value to x's value.
	// Reports whether operation is success.
	fn SHR(mut *self, x: Const): bool {
		i, mut ok := self.data.(big::Int)
		if !ok {
			return false
		}
		xi, ok := x.data.(big::Int)
		if !ok {
			return false
		}
		let mut r: big::Int
		r.Rsh(&i, uint(xi.U64()))
		self.SetInt(r)
		return true
	}

	fn String(*self): string {
		match {
		| self.IsNil():
			return "nil"
		| self.IsBool():
			if self.data.(bool) {
				return "true"
			}
			return "false"
		| self.IsString():
			return self.data.(string)
		| self.IsInt():
			i := self.data.(big::Int)
			return i.Format(10)
		| self.IsF64():
			return conv::FormatFloat(self.data.(f64), 'g', -1, 64)
		| self.IsCmplx128():
			return conv::FormatCmplx(self.data.(cmplx128), 'g', -1, 128)
		|:
			panic("unreachable")
		}
	}
}