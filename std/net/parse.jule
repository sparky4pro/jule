use "std/bufio"
use "std/internal/byteslite"
use "std/os"
use "std/time"

struct file {
	fd:   &os::File
	scan: &bufio::Scanner
}

impl file {
	async fn close(mut *self) {
		self.fd.Close().await!
	}

	async fn readLine(mut *self): (string, ok: bool) {
		ok = self.scan.Scan().await else {
			return "", false
		}
		return self.scan.Text(), ok
	}
}

fn open(name: string): (file, ok: bool) {
	mut fd := os::Open(name) else {
		return file{}, false
	}
	let mut f: file
	f.fd = fd
	f.scan = bufio::Scanner.New(fd)
	f.scan.Buffer(make([]byte, 0, 64*1024), 64*1024)
	return f, true
}

fn stat(name: string): (mtime: time::Time, size: i64, ok: bool) {
	st := os::Stat(name) else {
		return time::Time{}, 0, false
	}
	return st.ModTime(), st.Size(), true
}

// Count occurrences in s of any bytes in t.
#disable boundary
fn countAnyByte(s: string, t: string): int {
	mut n := 0
	mut i := 0
	for i < len(s); i++ {
		if byteslite::IndexByteString(t, s[i]) >= 0 {
			n++
		}
	}
	return n
}

// Split s at any bytes in t.
#disable boundary
fn splitAtBytes(s: string, t: string): []string {
	mut a := make([]string, 1+countAnyByte(s, t))
	mut n := 0
	mut last := 0
	mut i := 0
	for i < len(s); i++ {
		if byteslite::IndexByteString(t, s[i]) >= 0 {
			if last < i {
				a[n] = s[last:i]
				n++
			}
			last = i + 1
		}
	}
	if last < len(s) {
		a[n] = s[last:]
		n++
	}
	return a[0:n]
}

fn getFields(s: string): []string { return splitAtBytes(s, " \r\t\n") }

// Reports whether the given string contains at least one upper-case.
#disable boundary
fn hasUpperCase(s: string): bool {
	for i in s {
		if 'A' <= s[i] && s[i] <= 'Z' {
			return true
		}
	}
	return false
}

// Makes x ASCII lowercase in-place.
#disable boundary
fn lowerASCIIBytes(mut x: []byte) {
	for i, b in x {
		if 'A' <= b && b <= 'Z' {
			x[i] += 'a' - 'A'
		}
	}
}

// Returns the ASCII lowercase version of b.
fn lowerASCII(b: byte): byte {
	if 'A' <= b && b <= 'Z' {
		return b + ('a' - 'A')
	}
	return b
}