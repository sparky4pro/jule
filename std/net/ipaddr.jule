// Represents the address of an IP end point.
struct IPAddr {
	IP:   IP
	Zone: string // IPv6 scoped addressing zone
}

impl Addr for IPAddr {
	// Returns the address's network name, "ip".
	fn Network(*self): string {
		return "ip"
	}

	// Returns string form of address.
	fn String(*self): string {
		if self == nil {
			return "<nil>"
		}
		ip := self.IP.ipEmptyString()
		if self.Zone != "" {
			return ip + "%" + self.Zone
		}
		return ip
	}
}

impl IPAddr {
	// Returns an address of IP end point.
	// The network must be a IP network name.
	//
	// If the host in the address parameter is not a literal IP address or
	// the port is not a literal port number, it resolves the
	// address to an address of IP end point.
	// Otherwise, it parses the address as a pair of literal IP address
	// and port number.
	// The address parameter can use a host name, but this is not
	// recommended, because it will return at most one of the host name's
	// IP addresses.
	//
	// See the [Dial] function for a description of the network and address parameters.
	async fn Resolve(mut network: Network, address: string)!: &IPAddr {
		match network {
		| IP | IP4 | IP6:
			mut addrs := resolveInternetAddrList(network, address).await?
			return addrs.forResolve(network, address).(&IPAddr)
		|:
			throw &AddrError{Err: "invalid network: " + string(network)}
		}
	}
}