use "std/io"
use "std/sync"
use "std/time"

// Represents a DNS lookup error.
struct DNSError {
	Err:    string // description of the error
	Name:   string // name looked for
	Server: string // server used
}

impl DNSError {
	fn String(*self): string {
		if self == nil {
			return "<nil>"
		}
		mut s := "lookup " + self.Name
		if self.Server != "" {
			s += " on " + self.Server
		}
		s += ": " + self.Err
		return s
	}
}

fn newDNSError(err: string, name: string, server: string): &DNSError {
	return &DNSError{
		Err:    err,
		Name:   name,
		Server: server,
	}
}

// Network names.
enum Network: string {
	IP: "ip",
	IP4: "ip4",
	IP6: "ip6",
	TCP: "tcp",
	TCP4: "tcp4",
	TCP6: "tcp6",
	UDP: "udp",
	UDP4: "udp4",
	UDP6: "udp6",
}

fn networkToStr(net: Network): string {
	match net {
	| IP:
		return "ip"
	| IP4:
		return "ip4"
	| IP6:
		return "ip6"
	| TCP:
		return "tcp"
	| TCP4:
		return "tcp4"
	| TCP6:
		return "tcp6"
	| UDP:
		return "udp"
	| UDP4:
		return "udp4"
	| UDP6:
		return "udp6"
	}
	panic("unreachable")
}

// Common connection behavior.
// Inherits the io::Reader, io::Writer, and io::Closer traits.
trait Conn {
	io::Reader
	io::Writer
	io::Closer
	fn SetReadDeadline(mut *self, deadline: time::Duration)!
	fn SetWriteDeadline(mut *self, deadline: time::Duration)!
	fn Network(*self): Network
	fn RawFD(*self): u64
}

// Common listener behavior.
// Inherits the io::Closer trait.
trait Listener {
	io::Closer
	async fn Accept(*self)!: Conn
	fn Network(*self): Network
}

let mut maxListenerBacklogCacheInit = sync::AsyncOnce{}
let mut maxListenerBacklogCache = 0

// Caching wrapper around maxListenerBacklog.
async fn listenerBacklog(): int {
	maxListenerBacklogCacheInit.Do(async fn() {
		maxListenerBacklogCache = maxListenerBacklog().await
	}).await
	return maxListenerBacklogCache
}