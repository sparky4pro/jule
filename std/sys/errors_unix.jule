use "std/internal/conv"

extern let errno: int

fn GetLastErrno(): Errno { return Errno(extern.errno) }

fn formatError(e: Errno): string {
	if 0 <= int(e) && int(e) < len(errors) {
		s := errors[e]
		if s != "" {
			return s
		}
	}
	return "errno " + conv::Itoa(int(e))
}