fn StrFind(pattern: string, text: string): int {
	return strFinder.make(pattern).next(text)
}

fn DumpTables(pattern: string): ([256]int, []int) {
	mut finder := strFinder.make(pattern)
	return finder.badCharSkip, finder.goodSuffixSkip
}