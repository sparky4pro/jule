trait Foo {
	fn foo(*self): string
}

struct Bar{}

impl Baz for Bar {
	fn foo(*self): string {
		ret "bar"
	}
}

type Baz: Foo

impl Baz for Baz {
	fn foo(*self): string {
		ret "baz"
	}
}

fn init() {
	mut x := Foo(Bar{})
	if x.foo() != "bar" {
		panic("should be bar")
	}
	x = Foo(Baz(x))
	_, ok := x.(Baz)
	if ok {
		panic("should be not ok")
	}
	if x.foo() != "bar" {
		panic("should be bar")
	}
}