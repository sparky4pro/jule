use "std/jule"
use "std/unicode"
use "std/unicode/utf8"

// Reports whether the name is the valid identifier.
fn IsName(name: string): bool {
	if len(name) == 0 {
		return false
	}
	if jule::IsBlank(name) {
		return false
	}
	for i, r in name {
		if i == 0 {
			if r != '_' && !isLetter(r) {
				return false
			}
		} else if r != '_' && !isLetter(r) && !isDigit(r) {
			return false
		}
	}
	return true
}

fn isLetter(r: rune): bool {
	return 'a' <= r && r <= 'z' ||
		'A' <= r && r <= 'Z' ||
		r == '_' ||
		r >= utf8::RuneSelf && unicode::IsLetter(r)
}

fn isDigit(r: rune): bool {
	return '0' <= r && r <= '9' ||
		r >= utf8::RuneSelf && unicode::IsDigit(r)
}